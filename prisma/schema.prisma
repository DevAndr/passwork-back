generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  passwordHash       String
  masterPasswordHash String
  encryptionSalt     String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  passwords       Password[]
  folders         Folder[]
  tags            Tag[]
  refreshTokens   RefreshToken[]
  sharedByMe      SharedPassword[] @relation("SharedBy")
  sharedWithMe    SharedPassword[] @relation("SharedWith")

  @@map("users")
}

model Password {
  id                String            @id @default(uuid())
  userId            String
  title             String
  url               String?
  username          String?
  encryptedPassword String
  encryptedNotes    String?
  folderId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder  Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags    PasswordTag[]
  history PasswordHistory[]
  shares  SharedPassword[]

  @@map("passwords")
}

model Folder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]   @relation("FolderTree")
  passwords Password[]

  @@map("folders")
}

model Tag {
  id        String        @id @default(uuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwords PasswordTag[]

  @@unique([userId, name])
  @@map("tags")
}

model PasswordTag {
  passwordId String
  tagId      String

  password Password @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([passwordId, tagId])
  @@map("password_tags")
}

model PasswordHistory {
  id                String   @id @default(uuid())
  passwordId        String
  encryptedPassword String
  encryptedNotes    String?
  changedAt         DateTime @default(now())

  password Password @relation(fields: [passwordId], references: [id], onDelete: Cascade)

  @@map("password_history")
}

model SharedPassword {
  id               String   @id @default(uuid())
  passwordId       String
  sharedByUserId   String
  sharedWithUserId String
  encryptedKey     String
  createdAt        DateTime @default(now())

  password   Password @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  sharedBy   User     @relation("SharedBy", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User     @relation("SharedWith", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([passwordId, sharedWithUserId])
  @@map("shared_passwords")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
